# ============================================
# Lambrk Backend Environment Variables
# ============================================
# Copy this file to .env and update with your actual values
# Command: cp .env.example .env

# ============================================
# Database Configuration
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lambrk_user
POSTGRES_PASSWORD=lambrk_password
POSTGRES_DB=lambrk

# ============================================
# Service Ports
# ============================================
# Gateway port (default: 3100)
PORT=3100
GATEWAY_PORT=3100

# Individual service ports (if running separately)
AUTH_SERVICE_PORT=3101
VIDEO_SERVICE_PORT=3102

# ============================================
# Service URLs
# ============================================
# Used by gateway to proxy requests
AUTH_SERVICE_URL=http://localhost:3101
VIDEO_SERVICE_URL=http://localhost:3102

# ============================================
# JWT Configuration
# ============================================
# Secret key for signing JWT tokens (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Access token expiration (default: 7d)
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiration (default: 30d)
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_SECRET=your-refresh-token-secret-optional

# ============================================
# Google OAuth Configuration
# ============================================
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Create OAuth 2.0 credentials and add authorized redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3101/api/auth/google/callback

# ============================================
# CORS Configuration
# ============================================
# Allowed origin for CORS requests (frontend URL)
CORS_ORIGIN=http://localhost:3100

# ============================================
# Frontend Configuration
# ============================================
# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3100

# ============================================
# Node Environment
# ============================================
# Options: development, production, test
NODE_ENV=development

# ============================================
# Firebase Configuration
# ============================================
# Firebase project configuration for storage and real-time features
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id
